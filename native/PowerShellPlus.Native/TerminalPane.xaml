<UserControl x:Class="PowerShellPlus.Native.TerminalPane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:term="clr-namespace:EasyWindowsTerminalControl;assembly=EasyWindowsTerminalControl"
             MinWidth="180" MinHeight="130" Focusable="True">
  <Border x:Name="PaneBorder" Background="#11111B" BorderBrush="#313244" BorderThickness="1" CornerRadius="8" ClipToBounds="True" Margin="4" PreviewMouseLeftButtonDown="ActivatePane">
    <Grid>
      <Grid.RowDefinitions><RowDefinition Height="36"/><RowDefinition/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
      <Border Grid.Row="0" Background="#181825" BorderBrush="#313244" BorderThickness="0,0,0,1">
        <Grid Margin="10,0,5,0">
          <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
          <Ellipse x:Name="StateDot" Width="7" Height="7" Fill="#89B4FA" Margin="0,0,9,0"/>
          <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock x:Name="TitleText" FontSize="11" FontWeight="SemiBold"/>
            <TextBlock x:Name="StateText" Text="  Windows Terminal control" FontSize="9" Foreground="#6C7086" VerticalAlignment="Center"/>
          </StackPanel>
          <StackPanel Grid.Column="2" Orientation="Horizontal">
            <Button x:Name="PreviousOutputButton" Content="◷" ToolTip="Previous session output" Width="28" Height="26" Padding="0" Background="Transparent" BorderThickness="0" Visibility="Collapsed" Click="PreviousOutputClick"/>
            <Button Content="⌫" ToolTip="Clear" Width="28" Height="26" Padding="0" Background="Transparent" BorderThickness="0" Click="ClearClick"/>
            <Button Content="■" ToolTip="Stop" Width="28" Height="26" Padding="0" Background="Transparent" BorderThickness="0" Click="StopClick"/>
            <Button Content="↻" ToolTip="Restart" Width="28" Height="26" Padding="0" Background="Transparent" BorderThickness="0" Click="RestartClick"/>
            <Button x:Name="DetachButton" Content="&gt;_" ToolTip="Move to Windows Terminal" Width="28" Height="26" Padding="0" Background="Transparent" BorderThickness="0" FontFamily="Cascadia Mono" FontSize="9" FontWeight="SemiBold" Click="DetachClick"/>
            <Button Content="•••" ToolTip="Edit" Width="32" Height="26" Padding="0" Background="Transparent" BorderThickness="0" Click="EditClick"/>
            <Button Content="×" ToolTip="Close" Width="28" Height="26" Padding="0" Background="Transparent" BorderThickness="0" Foreground="#F38BA8" Click="CloseClick"/>
          </StackPanel>
        </Grid>
      </Border>
      <term:EasyTerminalControl x:Name="Terminal" Grid.Row="1" LogConPTYOutput="True" Win32InputMode="True" InputCapture="TabKey,DirectionKeys"/>
      <Border x:Name="CommandBarContainer" Grid.Row="2" MinHeight="16" Background="#151520" BorderBrush="#313244" BorderThickness="0,1,0,0" Opacity="1" ClipToBounds="True">
        <Grid x:Name="CommandBarContent" Margin="6,4">
          <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
          <Border Background="#11111B" BorderBrush="#45475A" BorderThickness="1" CornerRadius="5" ClipToBounds="True">
            <Grid>
              <Grid.ColumnDefinitions><ColumnDefinition Width="30"/><ColumnDefinition/><ColumnDefinition Width="54"/></Grid.ColumnDefinitions>
              <Button x:Name="QuickAccessButton" Content="&#x26A1;" Width="30" Height="26" Padding="0" VerticalAlignment="Bottom" Background="Transparent" BorderBrush="#313244" BorderThickness="0,0,1,0" Click="QuickAccessClick" ToolTip="Quick access commands"/>
              <TextBox x:Name="CommandInput" Grid.Column="1" MinLines="1" MaxLines="6" MinHeight="26" Padding="7,3" BorderThickness="0" Background="Transparent" FontFamily="Cascadia Mono" FontSize="11" AcceptsReturn="True" TextWrapping="Wrap" VerticalContentAlignment="Top" VerticalScrollBarVisibility="Auto" PreviewKeyDown="CommandInputPreviewKeyDown" PreviewKeyUp="CommandInputPreviewKeyUp" ToolTip="Enter runs · Ctrl+Enter queues · Up/Down browses queued commands"/>
              <Button x:Name="QueueCommandButton" Grid.Column="2" Width="54" Height="26" Padding="0" VerticalAlignment="Bottom" Background="Transparent" BorderBrush="#313244" BorderThickness="1,0,0,0" Click="QueueCommandClick" ToolTip="View command queue">
                <Grid><TextBlock Text="Queue" FontSize="9" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/><Border x:Name="QueueCountBadge" Visibility="Collapsed" Background="#89B4FA" CornerRadius="6" MinWidth="12" Height="12" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-3,-3,0"><TextBlock x:Name="QueueCountText" Text="0" Foreground="#11111B" FontSize="8" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border></Grid>
              </Button>
            </Grid>
          </Border>
          <Button x:Name="RunCommandButton" Grid.Column="1" Content="&#x25B6;" Width="30" Height="26" Padding="0" Margin="4,0,0,0" VerticalAlignment="Bottom" Click="RunCommandClick" MouseEnter="RunCommandMouseEnter" ToolTip="Run in this terminal (Enter)"/>
        </Grid>
      </Border>
      <Border x:Name="BottomCommandReveal" Grid.Row="2" Panel.ZIndex="5" Width="62" Height="16" Background="#01000000" HorizontalAlignment="Center" VerticalAlignment="Bottom">
        <Button x:Name="CommandBarToggle" Content="&#x2304;" Width="34" Height="16" Padding="0" HorizontalAlignment="Center" VerticalAlignment="Bottom" Background="#DD242438" BorderBrush="#585B70" Click="ToggleCommandBarClick" ToolTip="Hide command bar">
          <Button.Style><Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}"><Setter Property="Opacity" Value="0"/><Style.Triggers><DataTrigger Binding="{Binding IsMouseOver, ElementName=BottomCommandReveal}" Value="True"><Setter Property="Opacity" Value="1"/></DataTrigger><Trigger Property="IsKeyboardFocusWithin" Value="True"><Setter Property="Opacity" Value="1"/></Trigger></Style.Triggers></Style></Button.Style>
        </Button>
      </Border>
      <Border x:Name="RecoveryOverlay" Grid.Row="1" Panel.ZIndex="2" Background="#FA11111B" Visibility="Collapsed">
        <Grid Margin="12">
          <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition/></Grid.RowDefinitions>
          <Grid Grid.Row="0" Margin="2,0,2,9">
            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <StackPanel>
              <TextBlock Text="Previous session output" FontSize="13" FontWeight="SemiBold"/>
              <TextBlock x:Name="RecoveryTimestampText" Text="Recovered after restart" Foreground="#A6ADC8" FontSize="10" Margin="0,3,0,0"/>
            </StackPanel>
            <Button Grid.Column="1" Content="Continue to new terminal" Padding="10,5" Click="CloseRecoveryClick"/>
          </Grid>
          <TextBox x:Name="RecoveryOutputText" Grid.Row="1" IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap" FontFamily="Cascadia Mono" FontSize="11" Background="#0B0B12" BorderBrush="#45475A" Padding="10" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>
        </Grid>
      </Border>
    </Grid>
  </Border>
</UserControl>
