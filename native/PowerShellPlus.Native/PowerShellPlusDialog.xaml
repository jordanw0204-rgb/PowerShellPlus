<Window x:Class="PowerShellPlus.Native.PowerShellPlusDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PowerShellPlus" Width="540" SizeToContent="Height" MaxHeight="720"
        WindowStartupLocation="CenterOwner" WindowStyle="None" ResizeMode="NoResize"
        ShowInTaskbar="False" AllowsTransparency="True" Background="Transparent"
        Foreground="{StaticResource Text}">
  <Border Background="{StaticResource Bg}" BorderBrush="#585B70" BorderThickness="1" CornerRadius="12">
    <Border.Effect>
      <DropShadowEffect BlurRadius="30" ShadowDepth="10" Opacity="0.55" Color="#000000"/>
    </Border.Effect>
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="46"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <Border Background="{StaticResource Surface}" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1"
              CornerRadius="11,11,0,0" MouseLeftButtonDown="TitleBarMouseDown">
        <Grid Margin="16,0,7,0">
          <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
          <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <Image Source="Assets/PowerShellPlus.png" Width="19" Height="19" Margin="0,0,10,0"/>
            <TextBlock Text="PowerShellPlus" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
          </StackPanel>
          <Button Grid.Column="1" Content="&#x00D7;" Width="38" Height="34" Padding="0" Background="Transparent"
                  BorderThickness="0" FontSize="20" Foreground="{StaticResource Muted}" Click="CloseClick"
                  ToolTip="Close"/>
        </Grid>
      </Border>

      <Grid Grid.Row="1" Margin="24,23,24,22">
        <Grid.ColumnDefinitions><ColumnDefinition Width="46"/><ColumnDefinition/></Grid.ColumnDefinitions>
        <Border x:Name="IconBorder" Width="36" Height="36" HorizontalAlignment="Left" VerticalAlignment="Top"
                Background="#242438" BorderThickness="1" CornerRadius="18">
          <TextBlock x:Name="IconText" HorizontalAlignment="Center" VerticalAlignment="Center"
                     FontSize="18" FontWeight="Bold" FontFamily="Segoe UI Variable Display,Segoe UI"/>
        </Border>
        <StackPanel Grid.Column="1">
          <TextBlock x:Name="HeadingText" FontSize="19" FontWeight="SemiBold" TextWrapping="Wrap"/>
          <ScrollViewer MaxHeight="410" Margin="0,10,0,0" VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled">
            <TextBlock x:Name="MessageText" Foreground="#A6ADC8" FontSize="13" LineHeight="20"
                       TextWrapping="Wrap"/>
          </ScrollViewer>
        </StackPanel>
      </Grid>

      <Border Grid.Row="2" Background="{StaticResource Surface}" BorderBrush="{StaticResource Border}"
              BorderThickness="0,1,0,0" CornerRadius="0,0,11,11" Padding="18,14">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
          <Button x:Name="CancelActionButton" MinWidth="88" Height="36" Margin="0,0,8,0"
                  Click="CancelActionClick"/>
          <Button x:Name="SecondaryActionButton" MinWidth="104" Height="36" Margin="0,0,8,0"
                  Click="SecondaryActionClick"/>
          <Button x:Name="PrimaryActionButton" MinWidth="92" Height="36" Background="{StaticResource Accent}"
                  Foreground="{StaticResource Bg}" BorderBrush="{StaticResource Accent}" FontWeight="SemiBold"
                  Click="PrimaryActionClick"/>
        </StackPanel>
      </Border>
    </Grid>
  </Border>
</Window>
