<Window x:Class="PowerShellPlus.Native.LanRemoteDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LAN Remote" Icon="Assets/PowerShellPlus.ico" Width="560" Height="620"
        MinWidth="500" MinHeight="560" WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        Background="{StaticResource Bg}" Foreground="{StaticResource Text}">
  <Grid Margin="24">
    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition/><RowDefinition Height="Auto"/></Grid.RowDefinitions>

    <StackPanel>
      <TextBlock Text="LAN REMOTE" Foreground="{StaticResource Accent}" FontSize="10" FontWeight="Bold"/>
      <TextBlock Text="Your terminals, on this network" FontSize="24" FontWeight="SemiBold" Margin="0,5,0,0"/>
      <TextBlock Text="Open one of these addresses on your phone, then enter the pairing code. Every current session is mirrored live without moving or restarting its PowerShell process." Foreground="{StaticResource Muted}" TextWrapping="Wrap" LineHeight="19" Margin="0,10,0,0"/>
    </StackPanel>

    <Border Grid.Row="1" Margin="0,20,0,0" Padding="16" Background="{StaticResource Surface2}" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="9">
      <Grid>
        <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="150"/></Grid.ColumnDefinitions>
        <StackPanel>
          <TextBlock Text="PHONE ADDRESS" Foreground="{StaticResource Muted}" FontSize="9" FontWeight="Bold"/>
          <ListBox x:Name="AddressList" Margin="-10,5,0,0" MaxHeight="112" ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ListBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding}" FontFamily="Cascadia Mono,Consolas" FontSize="12" Foreground="#94E2D5"/></DataTemplate></ListBox.ItemTemplate>
          </ListBox>
        </StackPanel>
        <StackPanel Grid.Column="1" HorizontalAlignment="Right">
          <TextBlock Text="PAIRING CODE" Foreground="{StaticResource Muted}" FontSize="9" FontWeight="Bold" HorizontalAlignment="Right"/>
          <TextBlock x:Name="PairingCodeText" FontFamily="Cascadia Mono,Consolas" FontSize="25" FontWeight="SemiBold" Foreground="#F9E2AF" HorizontalAlignment="Right" Margin="0,5,0,0"/>
        </StackPanel>
      </Grid>
    </Border>

    <Grid Grid.Row="2" Margin="0,11,0,0">
      <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
      <TextBlock x:Name="ConnectionCountText" Text="0 phones connected" Foreground="{StaticResource Muted}" VerticalAlignment="Center"/>
      <Button Grid.Column="1" Content="Copy address" Margin="0,0,8,0" Click="CopyAddressClick"/>
      <Button Grid.Column="2" Content="Open on this PC" Click="OpenBrowserClick"/>
    </Grid>

    <StackPanel Grid.Row="3" Margin="0,22,0,0">
      <TextBlock Text="ACCESS" Foreground="{StaticResource Muted}" FontSize="9" FontWeight="Bold" Margin="0,0,0,9"/>
      <CheckBox x:Name="AllowInputToggle" Style="{StaticResource ToggleSwitch}" Content="Allow paired phones to type in terminals" Click="AllowInputChanged"/>
      <TextBlock Text="Read-only is the default. When enabled, phone keystrokes go directly to the selected live ConPTY session, so they have the same PowerShell and Codex permissions as that session." Foreground="{StaticResource Muted}" TextWrapping="Wrap" LineHeight="18" Margin="49,7,0,0"/>

      <Border Margin="0,22,0,0" Padding="14" Background="#2A202C" BorderBrush="#5A3947" BorderThickness="1" CornerRadius="8">
        <StackPanel>
          <TextBlock Text="Trusted private network only" Foreground="#F9E2AF" FontWeight="SemiBold"/>
          <TextBlock Text="This first LAN release uses local HTTP, so traffic is not encrypted. Use it only on a trusted Private Wi-Fi/Ethernet network. If Windows asks, allow PowerShellPlus on Private networks only—never Public networks. Stop sharing when finished." Foreground="#C9A9B6" TextWrapping="Wrap" LineHeight="18" Margin="0,6,0,0"/>
        </StackPanel>
      </Border>

      <TextBlock Text="For future away-from-home access, this server can be placed behind a private HTTPS tailnet proxy without changing the terminal protocol. Direct router port-forwarding is intentionally blocked by the LAN subnet policy." Foreground="{StaticResource Muted}" TextWrapping="Wrap" LineHeight="18" Margin="0,18,0,0"/>
    </StackPanel>

    <Grid Grid.Row="4" Margin="0,20,0,0">
      <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
      <Button Content="Stop sharing" Foreground="#F38BA8" BorderBrush="#5A3947" Background="#2A202C" HorizontalAlignment="Left" Click="StopSharingClick"/>
      <Button Grid.Column="2" Content="Done" MinWidth="88" Click="DoneClick"/>
    </Grid>
  </Grid>
</Window>
